# ===========================================
# REP RUMBLE - COMPLETE ENVIRONMENT SETUP
# ===========================================

# Server Configuration
PORT=5001
NODE_ENV=production
CLIENT_URL=https://your-frontend.vercel.app

# ===========================================
# SUPABASE (Auth - 50K users/month FREE)
# ===========================================
# 1. Go to https://supabase.com
# 2. Create project
# 3. Settings → API → Copy keys
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...your-anon-key
SUPABASE_SERVICE_KEY=eyJhbG...your-service-key

# ===========================================
# ORACLE DATABASE (20GB FREE per database)
# ===========================================
# 1. Go to https://cloud.oracle.com
# 2. Create Autonomous Database (ATP)
# 3. Download Wallet, get connection string
ORACLE_USER=ADMIN
ORACLE_PASSWORD=your-db-password
ORACLE_CONNECTION_STRING=(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=adb.ap-mumbai-1.oraclecloud.com))(connect_data=(service_name=xxxxx_reprumble_high.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))

# OR use TNS name if wallet is configured
# ORACLE_CONNECTION_STRING=reprumble_high
# TNS_ADMIN should point to the wallet folder if using a wallet
TNS_ADMIN=/path/to/wallet

# ===========================================
# AUTHENTICATION (JWT fallback)
# ===========================================
JWT_SECRET=your-super-secure-random-string-minimum-32-characters
JWT_EXPIRE=7d

# ===========================================
# AI - GEMINI (FREE - 1500 req/day)
# ===========================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...your-key

# ===========================================
# OPTIONAL: MongoDB (backup/migration)
# ===========================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/rep-rumble

# ===========================================
# OPTIONAL: OAuth Providers (via Supabase)
# ===========================================
# Configure in Supabase Dashboard → Authentication → Providers
# Google, Facebook, Apple, Twitter are all configured in Supabase UI
