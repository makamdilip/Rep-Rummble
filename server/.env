# ===========================================
# REP RUMBLE - SERVER CONFIGURATION
# ===========================================

# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ===========================================
# SUPABASE (Auth - 50K users/month FREE)
# Get from: https://supabase.com → Project Settings → API
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ===========================================
# ORACLE DATABASE (40GB FREE)
# Get from: Oracle Cloud → Autonomous Database → Connection
# For local development, you can use MongoDB instead (see below)
# ===========================================
ORACLE_USER=ADMIN
ORACLE_PASSWORD=your-oracle-password
ORACLE_CONNECTION_STRING=your-connection-string

# ===========================================
# MONGODB (Fallback/Migration - Use for local dev)
# Install MongoDB locally or use MongoDB Atlas
# ===========================================
MONGODB_URI=mongodb://localhost:27017/rep-rumble

# ===========================================
# JWT (Backup auth)
# ===========================================
JWT_SECRET=your-local-jwt-secret-change-in-production
JWT_EXPIRE=7d

# ===========================================
# GEMINI AI (FREE - 1500 req/day)
# Get from: https://aistudio.google.com/app/apikey
# ===========================================
ANTHROPIC_API_KEY=your-anthropic-key-if-using
GEMINI_API_KEY=your-gemini-key

# ===========================================
# OPTIONAL APIs
# ===========================================
OPENAI_API_KEY=your-openai-key
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_API_KEY=your-nutritionix-key
USDA_API_KEY=your-usda-key
