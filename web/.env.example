# ===========================================
# REP RUMBLE - FRONTEND ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# API URL (Your Backend on Oracle Cloud)
# ===========================================
# Development: Leave empty (uses Vite proxy)
# Production: Your Oracle Cloud VM IP or domain
VITE_API_URL=

# ===========================================
# SUPABASE (Auth - 50K users/month FREE)
# ===========================================
# Go to: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-key

# ===========================================
# OPTIONAL: Firebase (if still using)
# ===========================================
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
